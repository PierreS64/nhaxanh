### ========================================
### 1. ĐĂNG KÝ TÀI KHOẢN CHỦ NHÀ (LANDLORD)
### ========================================
POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "email": "chunha_vip@gmail.com",
  "password": "password123",
  "fullName": "Đại gia Bất Động Sản",
  "phone": "0987654321",
  "role": "LANDLORD"
}


### ========================================
### 2. ĐĂNG NHẬP ĐỂ LẤY THẺ TỪ (TOKEN)
### ========================================
POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "email": "chunha_vip@gmail.com",
  "password": "password123"
}

# (❗️) HƯỚNG DẪN BƯỚC NÀY:
# Bấm Send Request ở API số 2 này. 
# Nhìn sang cửa sổ bên phải, bạn sẽ thấy nó trả về một cái "access_token" dài loằng ngoằng.
# Hãy COPY đúng đoạn mã dài loằng ngoằng đó (không copy dấu ngoặc kép) để dùng cho bước 3.


### ========================================
### 3. TẠO PHÒNG TRỌ (YÊU CẦU PHẢI CÓ TOKEN)
### ========================================
# (❗️) HƯỚNG DẪN BƯỚC NÀY:
# Xóa dòng chữ [PASTE_TOKEN_CUA_BAN_VAO_DAY] và dán đoạn mã dài loằng ngoằng vừa copy ở bước 2 vào ngay sau chữ Bearer (nhớ giữ lại 1 dấu cách).

POST http://localhost:3000/properties
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjgyNDA0YzgxLWRjODQtNDYzNy1hNmM2LWM4NjJlNjliYWIxMCIsImVtYWlsIjoiY2h1bmhhX3ZpcEBnbWFpbC5jb20iLCJyb2xlIjoiTEFORExPUkQiLCJpYXQiOjE3Nzk4OTM4ODUsImV4cCI6MTc4MDQ5ODY4NX0.3wH_U1BxP4H5vn8qeCR496d-A59Zs7cSjU4zAyvO6Ys

{
  "title": "Phòng trọ Studio có ban công",
  "description": "Giờ giấc tự do, không chung chủ, thẻ từ thang máy.",
  "type": "ROOM",
  "price": 3500000,
  "area": 25,
  "depositAmount": 3500000,
  "address": "Ngõ 123 Cầu Giấy, Hà Nội",
  "latitude": 21.0381,
  "longitude": 105.7956
}


### ========================================
### 4. KHÁCH VÀO XEM NHÀ (KHÔNG CẦN TOKEN)
### ========================================
GET http://localhost:3000/properties


### ========================================
### 5. XÓA MỘT PHÒNG TRỌ CỤ THỂ (YÊU CẦU TOKEN)
### ========================================
# (❗️) HƯỚNG DẪN: 
# 1. Tôi đã điền sẵn ID phòng trọ từ ảnh trước của bạn vào cuối đường dẫn.
# 2. Bạn chỉ cần dán lại cái đoạn mã Token dài ngoằng vào sau chữ Bearer giống khối số 3 nhé.

DELETE http://localhost:3000/properties/a73af33d-3a1e-41e4-a7bd-816990c2b740
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjgyNDA0YzgxLWRjODQtNDYzNy1hNmM2LWM4NjJlNjliYWIxMCIsImVtYWlsIjoiY2h1bmhhX3ZpcEBnbWFpbC5jb20iLCJyb2xlIjoiTEFORExPUkQiLCJpYXQiOjE3Nzk4OTM4ODUsImV4cCI6MTc4MDQ5ODY4NX0.3wH_U1BxP4H5vn8qeCR496d-A59Zs7cSjU4zAyvO6Ys